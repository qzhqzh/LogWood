DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logwood?schema=public"

# For local dev, defaults to http://localhost:10001. Uncomment and set for production deployment.
# NEXTAUTH_URL="https://logwood.example.com"
# Required: NextAuth session encryption key. Must be at least 32 chars and
# unique per environment. Generate one with: openssl rand -base64 32
# DO NOT use a placeholder string in production - the app will refuse to boot.
NEXTAUTH_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Optional: fallback admin sign-in when OAuth providers are unavailable.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Prefer hash in production; if set, login checks password via bcrypt compare.
ADMIN_PASSWORD_HASH=""

# --- Security ---

# Set to "true" only when the app is behind a reverse proxy (nginx, cloud LB)
# that you trust to set X-Forwarded-For / X-Real-IP correctly. When false (the
# default) the app refuses to read those headers, preventing client IP spoofing.
LOGWOOD_TRUST_PROXY="true"

# HMAC key used to hash client IPs into rate-limit actor keys. Without this,
# the app falls back to plain SHA-256 and warns on boot in production. Generate
# with: openssl rand -base64 32
LOGWOOD_IP_HASH_SECRET=""
