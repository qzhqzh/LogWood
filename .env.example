DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logwood?schema=public"

# Production must be public https domain, for example: https://logwood.example.com
# Do not use localhost in production, otherwise login callback may redirect to localhost.
NEXTAUTH_URL="https://logwood.example.com"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Optional: fallback admin sign-in when OAuth providers are unavailable.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Prefer hash in production; if set, login checks password via bcrypt compare.
ADMIN_PASSWORD_HASH=""
