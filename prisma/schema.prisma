generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TargetType {
  editor
  coding
  model
  prompt
}

enum AppStatus {
  draft
  published
  archived
}

enum TagSentiment {
  good
  bad
}

enum ReviewStatus {
  published
  pending
  hidden
  deleted
}

enum CommentStatus {
  published
  pending
  hidden
  deleted
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ReportTargetType {
  review
  comment
  article
  article_comment
}

enum ReportStatus {
  open
  resolved
  rejected
}

enum RateLimitAction {
  review_create
  comment_create
  like_create
  report_create
}

enum ActorType {
  user
  anonymous
  ip_segment
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews       Review[]
  comments      Comment[]
  reviewLikes   ReviewLike[]
  commentLikes  CommentLike[]
  reports       Report[]
  articles      Article[]
  apps          App[]
  articleComments ArticleComment[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model AnonymousUser {
  id                  String   @id @default(cuid())
  deviceFingerprint   String   @unique
  displayName         String
  sequenceNumber      Int      @unique
  riskLevel           Int      @default(0)
  lastSeenAt          DateTime @default(now())
  createdAt           DateTime @default(now())

  reviews             Review[]
  comments            Comment[]
  reviewLikes         ReviewLike[]
  commentLikes        CommentLike[]
  reports             Report[]
  articleComments     ArticleComment[]

  @@map("anonymous_users")
}

model Target {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  type        TargetType
  logoUrl     String?
  description String?
  websiteUrl  String?
  developer   String?
  features    String
  createdAt   DateTime     @default(now())

  reviews     Review[]

  @@map("targets")
}

model Review {
  id               String        @id @default(cuid())
  userId           String?
  anonymousUserId  String?
  targetId         String
  category         String
  content          String
  rating           Int
  language         String        @default("zh")
  status           ReviewStatus  @default(published)
  qualityScore     Int           @default(0)
  likesCount       Int           @default(0)
  reportsCount     Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser? @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)
  target           Target        @relation(fields: [targetId], references: [id], onDelete: Cascade)
  likes            ReviewLike[]
  comments         Comment[]

  @@index([targetId])
  @@index([userId])
  @@index([anonymousUserId])
  @@index([status])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewLike {
  id               String        @id @default(cuid())
  reviewId         String
  userId           String?
  anonymousUserId  String?
  createdAt        DateTime      @default(now())

  review           Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser? @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@unique([reviewId, anonymousUserId])
  @@index([reviewId])
  @@map("review_likes")
}

model Comment {
  id               String          @id @default(cuid())
  reviewId         String
  userId           String?
  anonymousUserId  String?
  content          String
  language         String          @default("zh")
  status           CommentStatus   @default(published)
  likesCount       Int             @default(0)
  reportsCount     Int             @default(0)
  createdAt        DateTime        @default(now())

  review           Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)
  likes            CommentLike[]

  @@index([reviewId])
  @@index([status])
  @@map("comments")
}

model CommentLike {
  id               String          @id @default(cuid())
  commentId        String
  userId           String?
  anonymousUserId  String?
  createdAt        DateTime        @default(now())

  comment          Comment         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@unique([commentId, anonymousUserId])
  @@index([commentId])
  @@map("comment_likes")
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  columnId      String?
  excerpt       String?
  content       String
  tags          String        @default("[]")
  coverImageUrl String?
  status        ArticleStatus @default(draft)
  authorUserId  String?
  publishedAt   DateTime?
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author        User?         @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  column        ArticleColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  comments      ArticleComment[]

  @@index([columnId])
  @@index([status, publishedAt])
  @@index([createdAt])
  @@map("articles")
}

model ArticleColumn {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  articles  Article[]

  @@map("article_columns")
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  slug      String
  sentiment TagSentiment @default(good)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([slug])
  @@index([sentiment])
  @@map("tags")
}

model App {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  appUrl          String
  title           String
  summary         String
  description     String
  previewImageUrl String?
  tags            String    @default("[]")
  status          AppStatus @default(published)
  authorUserId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author          User?     @relation(fields: [authorUserId], references: [id])

  @@index([status, createdAt])
  @@map("apps")
}

model ArticleComment {
  id               String          @id @default(cuid())
  articleId        String
  userId           String?
  anonymousUserId  String?
  content          String
  language         String          @default("zh")
  status           CommentStatus   @default(published)
  likesCount       Int             @default(0)
  reportsCount     Int             @default(0)
  createdAt        DateTime        @default(now())

  article          Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([status])
  @@map("article_comments")
}

model Report {
  id                    String              @id @default(cuid())
  targetType            ReportTargetType
  targetId              String
  reason                String
  reporterUserId        String?
  reporterAnonymousId   String?
  status                ReportStatus        @default(open)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User?               @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)
  anonymousUser         AnonymousUser?      @relation(fields: [reporterAnonymousId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

model RateLimit {
  id          String          @id @default(cuid())
  action      RateLimitAction
  actorType   ActorType
  actorKey    String
  windowDate  DateTime
  count       Int             @default(0)
  updatedAt   DateTime        @updatedAt

  @@unique([action, actorType, actorKey, windowDate])
  @@index([action, actorType, actorKey])
  @@map("rate_limits")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
