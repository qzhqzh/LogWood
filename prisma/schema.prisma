generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TargetType {
  editor
  coding
  model
  prompt
}

enum AppStatus {
  draft
  published
  archived
}

enum CandidateStatus {
  watching
  evaluating
  promoted
  dropped
}

enum CandidatePromoteTo {
  tool
  gallery
}

enum TagSentiment {
  good
  bad
  neutral
}

enum ReviewStatus {
  published
  pending
  hidden
  deleted
}

enum EvaluationStatus {
  draft
  published
  archived
}

enum EvaluationProtocol {
  skill
  model
  software
  resource
}

enum EvaluationVerdict {
  verified
  conditional
  failed
  inconclusive
}

enum EvaluationReproducibility {
  untested
  single_run
  repeated
  reproduced
}

enum CommentStatus {
  published
  pending
  hidden
  deleted
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ReportTargetType {
  review
  comment
  article
  article_comment
}

enum ReportStatus {
  open
  resolved
  rejected
}

enum RateLimitAction {
  review_create
  comment_create
  like_create
  report_create
  // Phase-2 additions for admin login brute-force defence and upload abuse.
  admin_login_attempt
  article_upload
}

enum ActorType {
  user
  anonymous
  ip_segment
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  avatarUrl     String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews       Review[]
  evaluations   Evaluation[]
  comments      Comment[]
  reviewLikes   ReviewLike[]
  commentLikes  CommentLike[]
  articleLikes  ArticleLike[]
  reports       Report[]
  articles      Article[]
  apps          App[]
  skills        Skill[]
  candidates    Candidate[]
  articleComments ArticleComment[]
  accounts      Account[]
  sessions      Session[]
  adminAuditLogs AdminAuditLog[]

  @@map("users")
}

model AnonymousUser {
  id                  String   @id @default(cuid())
  deviceFingerprint   String   @unique
  displayName         String
  sequenceNumber      Int      @unique
  riskLevel           Int      @default(0)
  lastSeenAt          DateTime @default(now())
  createdAt           DateTime @default(now())

  reviews             Review[]
  comments            Comment[]
  reviewLikes         ReviewLike[]
  commentLikes        CommentLike[]
  articleLikes        ArticleLike[]
  reports             Report[]
  articleComments     ArticleComment[]

  @@map("anonymous_users")
}

model Target {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  type             TargetType
  logoUrl          String?
  description      String?
  websiteUrl       String?
  developer        String?
  features         String
  // Skill 室扩展字段（可空，兼容历史行）
  previewImageUrl  String?
  sourceUrl        String?
  compareGroup     String?
  createdAt        DateTime     @default(now())
  // Default to now() so existing rows get a non-null value during the
  // additive `prisma db push`. Auto-updates on every write thereafter.
  updatedAt        DateTime     @default(now()) @updatedAt

  reviews          Review[]
  evaluations      Evaluation[]

  @@index([compareGroup])
  @@map("targets")
}

model Review {
  id               String        @id @default(cuid())
  userId           String?
  anonymousUserId  String?
  /// Exactly one of targetId / skillId / appId / candidateId should be set (enforced in service).
  targetId         String?
  skillId          String?
  appId            String?
  candidateId      String?
  content          String
  rating           Int
  language         String        @default("zh")
  status           ReviewStatus  @default(published)
  qualityScore     Int           @default(0)
  likesCount       Int           @default(0)
  reportsCount     Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser? @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)
  target           Target?       @relation(fields: [targetId], references: [id], onDelete: Cascade)
  skill            Skill?        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  app              App?          @relation(fields: [appId], references: [id], onDelete: Cascade)
  candidate        Candidate?    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  likes            ReviewLike[]
  comments         Comment[]

  @@index([targetId])
  @@index([skillId])
  @@index([appId])
  @@index([candidateId])
  @@index([userId])
  @@index([anonymousUserId])
  @@index([status])
  @@index([createdAt])
  @@map("reviews")
}

/// Evaluation v2 is the formal, evidence-backed assessment layer.
/// Exactly one subject relation must be populated; the application service
/// enforces this invariant and validates protocol-specific publication gates.
model Evaluation {
  id                String                     @id @default(cuid())
  authorUserId      String?
  targetId          String?
  skillId           String?
  appId             String?
  candidateId       String?
  title             String
  protocol          EvaluationProtocol
  protocolVersion   Int                        @default(2)
  status            EvaluationStatus           @default(draft)
  verdict           EvaluationVerdict          @default(inconclusive)
  reproducibility   EvaluationReproducibility  @default(untested)
  subjectVersion    String?
  task              String
  environment       Json?
  input              String?
  procedure          String?
  output             String?
  evidence           Json?
  scores             Json?
  strengths          String?
  limitations        String?
  conclusion         String
  repeatCount        Int                        @default(1)
  testedAt           DateTime                   @default(now())
  publishedAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  author             User?                      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  target             Target?                    @relation(fields: [targetId], references: [id], onDelete: Cascade)
  skill              Skill?                     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  app                App?                       @relation(fields: [appId], references: [id], onDelete: Cascade)
  candidate          Candidate?                 @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@index([skillId])
  @@index([appId])
  @@index([candidateId])
  @@index([authorUserId])
  @@index([status, testedAt])
  @@index([protocol, status])
  @@map("evaluations")
}

model ReviewLike {
  id               String        @id @default(cuid())
  reviewId         String
  userId           String?
  anonymousUserId  String?
  createdAt        DateTime      @default(now())

  review           Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser? @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@unique([reviewId, anonymousUserId])
  @@index([reviewId])
  @@map("review_likes")
}

model Comment {
  id               String          @id @default(cuid())
  reviewId         String
  userId           String?
  anonymousUserId  String?
  content          String
  language         String          @default("zh")
  status           CommentStatus   @default(published)
  likesCount       Int             @default(0)
  reportsCount     Int             @default(0)
  createdAt        DateTime        @default(now())

  review           Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)
  likes            CommentLike[]

  @@index([reviewId])
  @@index([status])
  @@map("comments")
}

model CommentLike {
  id               String          @id @default(cuid())
  commentId        String
  userId           String?
  anonymousUserId  String?
  createdAt        DateTime        @default(now())

  comment          Comment         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@unique([commentId, anonymousUserId])
  @@index([commentId])
  @@map("comment_likes")
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  columnId      String?
  excerpt       String?
  content       String
  tags          String        @default("[]")
  coverImageUrl String?
  status        ArticleStatus @default(draft)
  authorUserId  String?
  publishedAt   DateTime?
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author        User?         @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  column        ArticleColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  comments      ArticleComment[]
  likes         ArticleLike[]

  @@index([columnId])
  @@index([status, publishedAt])
  @@index([createdAt])
  @@map("articles")
}

model ArticleColumn {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  articles  Article[]

  @@map("article_columns")
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  slug      String
  sentiment TagSentiment @default(good)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([slug])
  @@index([sentiment])
  @@map("tags")
}

model Emoji {
  id        String   @id @default(cuid())
  name      String
  symbol    String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emojis")
}

enum SkillStatus {
  draft
  published
  archived
}

model Skill {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  /// Grouping key for shelves, e.g. frontend / style / workflow / image / copy
  category       String
  summary        String?
  /// The skill body: prompt, instructions, or reusable text
  prompt         String
  effectImageUrl String?
  /// Short note describing what the effect shows
  effectNote     String?
  sourceUrl      String?
  tags           String      @default("[]")
  status         SkillStatus @default(published)
  authorUserId   String?
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  author         User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  reviews        Review[]
  evaluations    Evaluation[]

  @@index([status, category, sortOrder])
  @@index([status, updatedAt])
  @@map("skills")
}

model Candidate {
  id                String               @id @default(cuid())
  title             String
  slug              String               @unique
  summary           String?
  websiteUrl        String?
  sourceUrl         String?
  logoUrl           String?
  previewImageUrl   String?
  tags              String               @default("[]")
  status            CandidateStatus      @default(watching)
  sortOrder         Int                  @default(0)
  promotedTo        CandidatePromoteTo?
  promotedTargetId  String?
  promotedAppId     String?
  authorUserId      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  author            User?                @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  reviews           Review[]
  evaluations       Evaluation[]

  @@index([status, sortOrder])
  @@index([status, updatedAt])
  @@map("candidates")
}

model App {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  appUrl          String
  title           String
  summary         String
  description     String
  previewImageUrl String?
  tags            String    @default("[]")
  status          AppStatus @default(published)
  authorUserId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author          User?     @relation(fields: [authorUserId], references: [id])
  reviews         Review[]
  evaluations     Evaluation[]

  @@index([status, createdAt])
  @@map("apps")
}

model ArticleComment {
  id               String          @id @default(cuid())
  articleId        String
  userId           String?
  anonymousUserId  String?
  content          String
  language         String          @default("zh")
  status           CommentStatus   @default(published)
  likesCount       Int             @default(0)
  reportsCount     Int             @default(0)
  createdAt        DateTime        @default(now())

  article          Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([status])
  @@map("article_comments")
}

model ArticleLike {
  id               String          @id @default(cuid())
  articleId        String
  userId           String?
  anonymousUserId  String?
  createdAt        DateTime        @default(now())

  article          Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousUser    AnonymousUser?  @relation(fields: [anonymousUserId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@unique([articleId, anonymousUserId])
  @@index([articleId])
  @@map("article_likes")
}

model Report {
  id                    String              @id @default(cuid())
  targetType            ReportTargetType
  targetId              String
  reason                String
  reporterUserId        String?
  reporterAnonymousId   String?
  status                ReportStatus        @default(open)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User?               @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)
  anonymousUser         AnonymousUser?      @relation(fields: [reporterAnonymousId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

model RateLimit {
  id          String          @id @default(cuid())
  action      RateLimitAction
  actorType   ActorType
  actorKey    String
  windowDate  DateTime
  count       Int             @default(0)
  updatedAt   DateTime        @updatedAt

  @@unique([action, actorType, actorKey, windowDate])
  @@index([action, actorType, actorKey])
  @@map("rate_limits")
}

/// Records destructive admin actions (delete, hide, status flips) for
/// post-incident forensics. Append-only from the application's perspective:
/// rows are never updated and only ever deleted by retention jobs.
model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String   // e.g. 'article.delete', 'comment.hide', 'target.delete'
  targetType  String   // 'article' | 'comment' | 'review' | 'target' | 'app' | 'tag' | 'emoji'
  targetId    String
  metadata    String?  // JSON-encoded extra context
  createdAt   DateTime @default(now())

  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
